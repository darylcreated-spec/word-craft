{
  "manifest_version": 3,
  "name": "Word Craft Integration",
  "version": "1.0.0",
  "description": "Send selected text from any website or Google Doc straight into Word Craft Paraphraser & AI Humanizer.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}
